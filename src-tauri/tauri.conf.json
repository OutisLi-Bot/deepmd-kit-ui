{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeePMD Studio",
  "version": "0.2.0",
  "identifier": "org.deepmodeling.deepmd-studio",
  "build": {
    "beforeDevCommand": "pnpm prepare:sidecar:debug && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm prepare:tauri",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeePMD Studio",
        "label": "main",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "center": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Train, evaluate, and manage DeePMD models",
    "longDescription": "A modern desktop workbench for the complete DeePMD-kit Python toolchain.",
    "resources": {
      "resources/runtime": "runtime",
      "../scripts/runtime_manager.py": "runtime-manager/runtime_manager.py",
      "../python/deepmd_ui/bridge.py": "bridge/deepmd_ui_bridge.py"
    },
    "externalBin": [
      "binaries/dpstudio"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
